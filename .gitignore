# ===========================
# 1. 核心过滤 (一定要有)
# ===========================

# 忽略虚拟环境 (非常重要！不要上传 venv 文件夹)
venv/
env/
.venv/
Scripts/

# 忽略 Python 编译缓存 (垃圾文件)
__pycache__/
*.py[cod]
*$py.class

# ===========================
# 2. 模型文件过滤 (GitHub 限制 100MB)
# ===========================

# 忽略所有的 PyTorch 模型权重文件
*.pth
*.pt
*.ckpt
*.safetensors
*.onnx

# 特别指定 models 文件夹下的模型也不要上传
models/*.pth
models/*.pt

# ===========================
# 3. 系统与 IDE 配置文件
# ===========================

# Windows 缩略图缓存
Thumbs.db
ehthumbs.db
Desktop.ini

# Mac 系统文件
.DS_Store

# VS Code 配置 (如果你不想上传个人的编辑器配置)
# 如果你希望别人也拥有那个路径自动补全的配置，可以用 # 注释掉下面这一行
.vscode/

# PyCharm 配置
.idea/

# ===========================
# 4. 其他临时文件
# ===========================
*.log
*.tmp
# 如果你自己生成了测试视频，也忽略掉
*.mp4
*.avi